{
  "$defs": {
    "EvidenceArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "logical_name": {
          "minLength": 1,
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "media_type",
        "digest",
        "size_bytes",
        "relative_path"
      ],
      "title": "EvidenceArtifactRef",
      "type": "object"
    }
  },
  "$id": "urn:pmorg:contract:pmorg.source-scope-manifest/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "commit": {
      "pattern": "^[0-9a-f]{40}$",
      "title": "Commit",
      "type": "string"
    },
    "derivation_evidence_bundle": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "derivation_policy_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Derivation Policy Hash",
      "type": "string"
    },
    "duplicate_path_count": {
      "minimum": 0,
      "title": "Duplicate Path Count",
      "type": "integer"
    },
    "expected_path_count": {
      "minimum": 0,
      "title": "Expected Path Count",
      "type": "integer"
    },
    "generator_artifact_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Generator Artifact Digest",
      "type": "string"
    },
    "generator_identity": {
      "minLength": 1,
      "title": "Generator Identity",
      "type": "string"
    },
    "path_inventory": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "repository": {
      "minLength": 1,
      "title": "Repository",
      "type": "string"
    },
    "roots": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Roots",
      "type": "array"
    },
    "schema_version": {
      "const": "pmorg.source-scope-manifest/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "scope_kind": {
      "enum": [
        "pmorg",
        "onyx_ce",
        "onyx_ee"
      ],
      "title": "Scope Kind",
      "type": "string"
    },
    "tree_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Tree Hash",
      "type": "string"
    },
    "unreadable_path_count": {
      "minimum": 0,
      "title": "Unreadable Path Count",
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "repository",
    "commit",
    "scope_kind",
    "roots",
    "tree_hash",
    "path_inventory",
    "derivation_policy_hash",
    "generator_identity",
    "generator_artifact_digest",
    "derivation_evidence_bundle",
    "expected_path_count",
    "duplicate_path_count",
    "unreadable_path_count"
  ],
  "title": "SourceScopeManifest",
  "type": "object",
  "x-pmorg-schema-version": "pmorg.source-scope-manifest/v1",
  "x-pmorg-wire-surface": "pmorg-contracts/1.0"
}
