{
  "$defs": {
    "CeReleaseAuthorizationBinding": {
      "additionalProperties": false,
      "properties": {
        "artifact_scope_policy_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Scope Policy Hash",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "issuer_identity": {
          "minLength": 1,
          "title": "Issuer Identity",
          "type": "string"
        },
        "next_revalidation_at": {
          "format": "date-time",
          "title": "Next Revalidation At",
          "type": "string"
        },
        "permitted_onyx_surface": {
          "const": "ce",
          "title": "Permitted Onyx Surface",
          "type": "string"
        },
        "permitted_operations": {
          "items": {
            "enum": [
              "deploy",
              "startup",
              "registry_publish",
              "artifact_export"
            ],
            "type": "string"
          },
          "minItems": 1,
          "title": "Permitted Operations",
          "type": "array"
        },
        "permitted_usage_mode": {
          "const": "production",
          "title": "Permitted Usage Mode",
          "type": "string"
        },
        "release_evidence": {
          "$ref": "#/$defs/EvidenceArtifactRef"
        },
        "release_id": {
          "minLength": 1,
          "title": "Release Id",
          "type": "string"
        },
        "revocation_status": {
          "$ref": "#/$defs/EvidenceArtifactRef"
        },
        "schema_version": {
          "const": "pmorg.ce-release-authorization-binding/v1",
          "title": "Schema Version",
          "type": "string"
        },
        "target_destination_scope_policy_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Target Destination Scope Policy Hash",
          "type": "string"
        },
        "temporal_policy": {
          "$ref": "#/$defs/TemporalPolicyBinding"
        },
        "trusted_clock_id": {
          "minLength": 1,
          "title": "Trusted Clock Id",
          "type": "string"
        },
        "trusted_time_receipt_envelope": {
          "$ref": "#/$defs/EvidenceArtifactRef"
        },
        "valid_from": {
          "format": "date-time",
          "title": "Valid From",
          "type": "string"
        },
        "valid_until": {
          "format": "date-time",
          "title": "Valid Until",
          "type": "string"
        },
        "verification_material_bundle": {
          "$ref": "#/$defs/EvidenceArtifactRef"
        },
        "verification_policy_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Verification Policy Hash",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "release_id",
        "issuer_identity",
        "release_evidence",
        "permitted_onyx_surface",
        "permitted_usage_mode",
        "permitted_operations",
        "artifact_scope_policy_hash",
        "target_destination_scope_policy_hash",
        "valid_from",
        "valid_until",
        "next_revalidation_at",
        "trusted_clock_id",
        "trusted_time_receipt_envelope",
        "temporal_policy",
        "revocation_status",
        "verification_policy_hash",
        "verification_material_bundle",
        "issued_at"
      ],
      "title": "CeReleaseAuthorizationBinding",
      "type": "object"
    },
