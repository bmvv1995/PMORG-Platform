  "$id": "urn:pmorg:contract:pmorg.distribution-admission/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "admission_basis": {
      "enum": [
        "synthetic_environment",
        "ce_release",
        "onyx_enterprise_authorization"
      ],
      "title": "Admission Basis",
      "type": "string"
    },
    "admission_id": {
      "format": "uuid7",
      "title": "Admission Id",
      "type": "string"
    },
    "artifact_set_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Artifact Set Hash",
      "type": "string"
    },
    "build_attestation_envelope_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Build Attestation Envelope Hash",
      "type": "string"
    },
    "build_manifest_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Build Manifest Hash",
      "type": "string"
    },
    "ce_release_authorization": {
      "anyOf": [
        {
          "$ref": "#/$defs/CeReleaseAuthorizationBinding"
        },
        {
          "type": "null"
        }
      ]
    },
    "destination_class": {
      "enum": [
        "controlled_synthetic_registry",
        "client_destination"
      ],
      "title": "Destination Class",
      "type": "string"
    },
    "destination_descriptor_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Destination Descriptor Hash",
      "type": "string"
    },
    "destination_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Destination Fingerprint",
      "type": "string"
    },
    "destination_measurement_envelope_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Destination Measurement Envelope Hash",
      "type": "string"
    },
    "distribution_payload_descriptor_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Distribution Payload Descriptor Hash",
      "type": "string"
    },
    "distribution_payload_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Distribution Payload Hash",
      "type": "string"
    },
    "enterprise_authorization": {
      "anyOf": [
        {
          "$ref": "#/$defs/EnterpriseAuthorizationBinding"
        },
        {
          "type": "null"
        }
      ]
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "next_revalidation_at": {
      "format": "date-time",
      "title": "Next Revalidation At",
      "type": "string"
    },
    "onyx_surface": {
      "enum": [
        "ce",
        "ee"
      ],
      "title": "Onyx Surface",
      "type": "string"
    },
    "operation": {
      "enum": [
        "registry_publish",
        "artifact_export"
      ],
      "title": "Operation",
      "type": "string"
    },
    "revocation_status": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "schema_version": {
      "const": "pmorg.distribution-admission/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "temporal_policy": {
      "$ref": "#/$defs/TemporalPolicyBinding"
    },
    "trusted_clock_id": {
      "minLength": 1,
      "title": "Trusted Clock Id",
      "type": "string"
    },
    "trusted_time_receipt_envelope": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "usage_mode": {
      "enum": [
        "development_test",
        "production"
      ],
      "title": "Usage Mode",
      "type": "string"
    },
    "valid_from": {
      "format": "date-time",
      "title": "Valid From",
      "type": "string"
    },
    "valid_until": {
      "format": "date-time",
      "title": "Valid Until",
      "type": "string"
    },
    "verification_material_bundle": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "verification_policy_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Verification Policy Hash",
      "type": "string"
    },
    "verifier_identity": {
      "minLength": 1,
      "title": "Verifier Identity",
      "type": "string"
    },
    "verifier_receipt": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    }
  },
  "required": [
    "schema_version",
    "admission_id",
    "operation",
    "artifact_set_hash",
    "build_manifest_hash",
    "build_attestation_envelope_hash",
    "distribution_payload_descriptor_hash",
    "distribution_payload_hash",
    "onyx_surface",
    "usage_mode",
    "destination_descriptor_hash",
    "destination_fingerprint",
    "destination_measurement_envelope_hash",
    "destination_class",
    "admission_basis",
    "ce_release_authorization",
    "enterprise_authorization",
    "valid_from",
    "valid_until",
    "next_revalidation_at",
    "trusted_clock_id",
    "trusted_time_receipt_envelope",
    "temporal_policy",
    "revocation_status",
    "verifier_identity",
    "verification_policy_hash",
    "verification_material_bundle",
    "verifier_receipt",
    "issued_at"
  ],
  "title": "DistributionAdmissionRecord",
  "type": "object",
  "x-pmorg-schema-version": "pmorg.distribution-admission/v1",
  "x-pmorg-wire-surface": "pmorg-contracts/1.0"
}
