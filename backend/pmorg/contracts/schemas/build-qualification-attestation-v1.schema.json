{
  "$defs": {
    "EvidenceArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "logical_name": {
          "minLength": 1,
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "media_type",
        "digest",
        "size_bytes",
        "relative_path"
      ],
      "title": "EvidenceArtifactRef",
      "type": "object"
    },
    "TemporalPolicyBinding": {
      "additionalProperties": false,
      "properties": {
        "max_clock_skew_seconds": {
          "minimum": 0,
          "title": "Max Clock Skew Seconds",
          "type": "integer"
        },
        "max_measurement_age_seconds": {
          "minimum": 0,
          "title": "Max Measurement Age Seconds",
          "type": "integer"
        },
        "max_revalidation_interval_seconds": {
          "minimum": 0,
          "title": "Max Revalidation Interval Seconds",
          "type": "integer"
        },
        "max_time_receipt_age_seconds": {
          "minimum": 0,
          "title": "Max Time Receipt Age Seconds",
          "type": "integer"
        },
        "max_validity_seconds": {
          "minimum": 0,
          "title": "Max Validity Seconds",
          "type": "integer"
        },
        "policy_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Policy Hash",
          "type": "string"
        }
      },
      "required": [
        "policy_hash",
        "max_clock_skew_seconds",
        "max_time_receipt_age_seconds",
        "max_measurement_age_seconds",
        "max_validity_seconds",
        "max_revalidation_interval_seconds"
      ],
      "title": "TemporalPolicyBinding",
      "type": "object"
    }
  },
  "$id": "urn:pmorg:contract:pmorg.build-qualification-attestation/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_set_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Artifact Set Hash",
      "type": "string"
    },
    "build_manifest_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Build Manifest Hash",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "next_revalidation_at": {
      "format": "date-time",
      "title": "Next Revalidation At",
      "type": "string"
    },
    "qualification_bundle_index_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Qualification Bundle Index Hash",
      "type": "string"
    },
    "revocation_status": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "schema_version": {
      "const": "pmorg.build-qualification-attestation/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "temporal_policy": {
      "$ref": "#/$defs/TemporalPolicyBinding"
    },
    "trusted_clock_id": {
      "minLength": 1,
      "title": "Trusted Clock Id",
      "type": "string"
    },
    "trusted_time_receipt_envelope": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "valid_from": {
      "format": "date-time",
      "title": "Valid From",
      "type": "string"
    },
    "valid_until": {
      "format": "date-time",
      "title": "Valid Until",
      "type": "string"
    },
    "verification_material_bundle": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "verification_policy_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Verification Policy Hash",
      "type": "string"
    },
    "verifier_identity": {
      "minLength": 1,
      "title": "Verifier Identity",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "build_manifest_hash",
    "artifact_set_hash",
    "qualification_bundle_index_hash",
    "valid_from",
    "valid_until",
    "next_revalidation_at",
    "trusted_clock_id",
    "trusted_time_receipt_envelope",
    "temporal_policy",
    "revocation_status",
    "verification_material_bundle",
    "verifier_identity",
    "verification_policy_hash",
    "issued_at"
  ],
  "title": "BuildQualificationAttestation",
  "type": "object",
  "x-pmorg-schema-version": "pmorg.build-qualification-attestation/v1",
  "x-pmorg-wire-surface": "pmorg-contracts/1.0"
}
