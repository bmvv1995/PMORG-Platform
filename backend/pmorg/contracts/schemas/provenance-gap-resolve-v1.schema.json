        "logical_name": {
          "minLength": 1,
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "media_type",
        "digest",
        "size_bytes",
        "relative_path"
      ],
      "title": "EvidenceArtifactRef",
      "type": "object"
    }
  },
  "$id": "urn:pmorg:contract:pmorg.provenance-gap.resolve/v1",
