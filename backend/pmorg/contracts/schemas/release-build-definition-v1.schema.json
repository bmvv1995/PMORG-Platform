{
  "$defs": {
    "EvidenceArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "logical_name": {
          "minLength": 1,
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "media_type",
        "digest",
        "size_bytes",
        "relative_path"
      ],
      "title": "EvidenceArtifactRef",
      "type": "object"
    }
  },
  "$id": "urn:pmorg:contract:pmorg.release-build-definition/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_usage_modes": {
      "items": {
        "enum": [
          "development_test",
          "production"
        ],
        "type": "string"
      },
      "minItems": 1,
      "title": "Allowed Usage Modes",
      "type": "array"
    },
    "approval_authority": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "baseline_manifest_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Baseline Manifest Hash",
      "type": "string"
    },
    "build_input_set": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "build_recipe": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "expected_artifact_catalog_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Expected Artifact Catalog Hash",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "onyx_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "title": "Onyx Commit",
      "type": "string"
    },
    "onyx_surface": {
      "enum": [
        "ce",
        "ee"
      ],
      "title": "Onyx Surface",
      "type": "string"
    },
    "pmorg_platform_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "title": "Pmorg Platform Commit",
      "type": "string"
    },
    "pmorg_spec_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "title": "Pmorg Spec Commit",
      "type": "string"
    },
    "qualification_policy_map_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Qualification Policy Map Hash",
      "type": "string"
    },
    "runtime_scope_policy_map": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "schema_version": {
      "const": "pmorg.release-build-definition/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "verification_material_bundle": {
      "$ref": "#/$defs/EvidenceArtifactRef"
    },
    "verification_policy_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Verification Policy Hash",
      "type": "string"
    },
    "verifier_identity": {
      "minLength": 1,
      "title": "Verifier Identity",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "baseline_manifest_hash",
    "pmorg_spec_commit",
    "pmorg_platform_commit",
    "onyx_commit",
    "onyx_surface",
    "allowed_usage_modes",
    "build_recipe",
    "build_input_set",
    "expected_artifact_catalog_hash",
    "qualification_policy_map_hash",
    "runtime_scope_policy_map",
    "approval_authority",
    "verifier_identity",
    "verification_policy_hash",
    "verification_material_bundle",
    "issued_at"
  ],
  "title": "ReleaseBuildDefinitionPayload",
  "type": "object",
  "x-pmorg-schema-version": "pmorg.release-build-definition/v1",
  "x-pmorg-wire-surface": "pmorg-contracts/1.0"
}
