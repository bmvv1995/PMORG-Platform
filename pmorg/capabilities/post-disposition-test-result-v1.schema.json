{
  "$id": "urn:pmorg:evidence:post-disposition-test-result:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capability_id": {
      "enum": [
        "deployment-admission",
        "distribution-admission"
      ]
    },
    "error_count": {
      "minimum": 0,
      "type": "integer"
    },
    "expected_failure_count": {
      "minimum": 0,
      "type": "integer"
    },
    "failure_count": {
      "minimum": 0,
      "type": "integer"
    },
    "fully_qualified_name": {
      "minLength": 1,
      "type": "string"
    },
    "implementation_path_set_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "patch_ledger_set_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "runtime_identity_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "runtime_measurement": {
      "additionalProperties": false,
      "properties": {
        "declared_artifacts": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "pattern": "^sha256:[0-9a-f]{64}$",
                "type": "string"
              },
              "relative_path": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "digest",
              "relative_path"
            ],
            "type": "object"
          },
          "maxItems": 3,
          "minItems": 3,
          "type": "array"
        },
        "interpreter_binary": {
          "additionalProperties": false,
          "properties": {
            "digest": {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            "relative_path": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "digest",
            "relative_path"
          ],
          "type": "object"
        }
      },
      "required": [
        "declared_artifacts",
        "interpreter_binary"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "pmorg.post-disposition-test-result/v1"
    },
    "skipped_count": {
      "minimum": 0,
      "type": "integer"
    },
    "test_id": {
      "minLength": 1,
      "type": "string"
    },
    "test_manifest_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "tests_run": {
      "const": 1
    },
    "unexpected_success_count": {
      "minimum": 0,
      "type": "integer"
    },
    "verdict": {
      "enum": [
        "pass",
        "fail"
      ]
    }
  },
  "required": [
    "schema_version",
    "capability_id",
    "test_id",
    "fully_qualified_name",
    "test_manifest_digest",
    "implementation_path_set_hash",
    "patch_ledger_set_hash",
    "runtime_identity_digest",
    "runtime_measurement",
    "tests_run",
    "failure_count",
    "error_count",
    "skipped_count",
    "expected_failure_count",
    "unexpected_success_count",
    "verdict"
  ],
  "title": "PMORG post-disposition test result",
  "type": "object"
}
