    "active_oracle_state": {
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "null"
        },
        "candidate_test_vector": {
          "type": "null"
        },
        "oracle_status": {
          "const": "unexecutable"
        }
      },
      "required": [
        "adapter",
        "candidate_test_vector",
        "oracle_status"
      ],
      "type": "object"
    },
    "blob_set_membership_count": {
      "const": 5155
    },
    "blob_set_scan_count": {
      "const": 55
    },
    "blob_set_scans": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "blob_count": {
            "minimum": 1,
            "type": "integer"
          },
          "blob_index_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "blob_set_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "candidate_group": {
            "minLength": 1,
            "type": "string"
          },
          "coverage": {
            "additionalProperties": false,
            "properties": {
              "expected": {
                "minimum": 1,
                "type": "integer"
              },
              "scanned": {
                "minimum": 1,
                "type": "integer"
              },
              "unreadable": {
                "const": 0
              },
              "unverified": {
                "const": 0
              }
            },
            "required": [
              "expected",
              "scanned",
              "unreadable",
              "unverified"
            ],
            "type": "object"
          },
          "scan_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "signal_paths": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "categories": {
                  "items": {
                    "enum": [
                      "historical_evidence",
                      "ownership_routing",
                      "seam_governance",
                      "trust_boundary",
                      "upstream_governance"
                    ]
                  },
                  "minItems": 1,
                  "type": "array",
                  "uniqueItems": true
                },
                "git_object_id": {
                  "pattern": "^[0-9a-f]{40}$",
                  "type": "string"
                },
                "path": {
                  "minLength": 1,
                  "type": "string"
                },
                "sha256": {
                  "pattern": "^sha256:[0-9a-f]{64}$",
                  "type": "string"
                }
              },
              "required": [
                "categories",
                "git_object_id",
                "path",
                "sha256"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "source_surface": {
            "enum": [
              "ce",
              "ee"
            ]
          }
        },
        "required": [
          "blob_count",
          "blob_index_digest",
          "blob_set_digest",
          "candidate_group",
          "coverage",
          "scan_digest",
          "signal_paths",
          "source_surface"
        ],
        "type": "object"
      },
      "maxItems": 55,
      "minItems": 55,
      "type": "array"
    },
    "candidate_blob_membership_count": {
      "const": 5155
    },
    "candidate_count": {
      "const": 55
    },
    "candidate_inputs": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
