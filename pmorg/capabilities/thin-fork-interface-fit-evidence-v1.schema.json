          "blob_set_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "candidate_group": {
            "minLength": 1,
            "type": "string"
          },
          "candidate_id": {
            "minLength": 1,
            "type": "string"
          },
          "candidate_manifest_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "plausibility_state": {
            "enum": [
              "lexical_signals_present_no_fit_inference",
              "no_lexical_signal_present_no_fit_inference"
