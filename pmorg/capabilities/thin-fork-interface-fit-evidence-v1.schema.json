        "relative_path": {
          "minLength": 1,
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "digest",
        "relative_path",
        "size_bytes"
      ],
      "type": "object"
    },
    "candidate_search_evidence": {
      "additionalProperties": false,
