      "maxItems": 55,
      "minItems": 55,
      "type": "array"
    },
    "capability_id": {
      "const": "thin-fork-boundary"
    },
    "claim_boundary": {
      "const": "exhaustive_plausibility_screen_only_no_qualification_or_disposition"
