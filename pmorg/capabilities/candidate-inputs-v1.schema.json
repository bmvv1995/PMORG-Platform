{
  "$id": "urn:pmorg:candidate-input-bundle:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blob_set_count": {
      "minimum": 1,
      "type": "integer"
    },
    "blob_set_membership_count": {
      "minimum": 1,
      "type": "integer"
    },
    "blob_sets": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "blob_count": {
            "minimum": 1,
            "type": "integer"
          },
          "blob_set_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "blobs": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "git_object_id": {
                  "pattern": "^[0-9a-f]{40}$",
                  "type": "string"
                },
                "mode": {
                  "pattern": "^[0-9]{6}$",
                  "type": "string"
                },
                "path": {
                  "minLength": 1,
                  "type": "string"
                },
                "sha256": {
                  "pattern": "^sha256:[0-9a-f]{64}$",
                  "type": "string"
                },
                "size_bytes": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "git_object_id",
                "mode",
                "path",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "candidate_group": {
            "minLength": 1,
            "type": "string"
          },
          "schema_version": {
            "const": "pmorg.candidate-blob-set/v1"
          },
          "source_commit": {
            "const": "1da679cefc96165c6b9b64c3bc769584b88f88c2"
          },
          "source_repository": {
            "const": "https://github.com/onyx-dot-app/onyx.git"
          },
          "source_surface": {
            "enum": [
              "ce",
              "ee"
            ]
          },
          "source_tree_id": {
            "const": "7696e9ff17a5ddc9acc0e7e21a1d213925056a58"
          }
