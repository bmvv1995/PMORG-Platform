              "logical_name": {
                "minLength": 1,
                "type": "string"
              },
              "media_type": {
                "minLength": 1,
                "type": "string"
              },
              "relative_path": {
                "minLength": 1,
                "type": "string"
              },
              "size_bytes": {
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "digest",
              "logical_name",
              "media_type",
              "relative_path",
              "size_bytes"
            ],
            "type": "object"
          },
          "source_repository": {
            "const": "https://github.com/onyx-dot-app/onyx.git"
          },
          "source_surface": {
            "enum": [
              "ce",
              "ee"
            ]
          },
          "source_tree_id": {
            "const": "7696e9ff17a5ddc9acc0e7e21a1d213925056a58"
          }
        },
        "required": [
          "schema_version",
