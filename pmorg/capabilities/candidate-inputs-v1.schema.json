                "minLength": 1,
                "type": "string"
              },
              "media_type": {
                "minLength": 1,
                "type": "string"
              },
              "relative_path": {
                "minLength": 1,
                "type": "string"
              },
              "size_bytes": {
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "digest",
              "logical_name",
              "media_type",
              "relative_path",
              "size_bytes"
            ],
            "type": "object"
          },
          "schema_version": {
            "const": "pmorg.candidate-input-manifest/v1"
          },
          "source_commit": {
            "const": "1da679cefc96165c6b9b64c3bc769584b88f88c2"
          },
          "source_inventory": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "pattern": "^sha256:[0-9a-f]{64}$",
                "type": "string"
