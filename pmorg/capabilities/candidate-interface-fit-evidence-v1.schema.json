{
  "$id": "urn:pmorg:candidate-interface-fit-evidence:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "candidate_count": {
      "const": 12
    },
    "candidate_inputs": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "digest",
        "relative_path",
        "size_bytes"
      ],
      "type": "object"
    },
    "candidates": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "blob_count": {
            "minimum": 1,
            "type": "integer"
          },
          "blob_set_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "candidate_group": {
            "minLength": 1,
            "type": "string"
          },
          "candidate_id": {
            "minLength": 1,
            "type": "string"
          },
          "candidate_manifest_digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "capability_id": {
            "enum": [
              "deployment-admission",
              "distribution-admission"
            ]
          },
          "coverage": {
            "additionalProperties": false,
            "properties": {
              "expected": {
                "minimum": 1,
                "type": "integer"
              },
              "scanned": {
                "minimum": 1,
                "type": "integer"
              },
              "unreadable": {
                "const": 0
              },
              "unverified": {
                "const": 0
              }
            },
            "required": [
              "expected",
              "scanned",
              "unreadable",
              "unverified"
            ],
            "type": "object"
          },
          "inspected_blobs": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "git_object_id": {
                  "pattern": "^[0-9a-f]{40}$",
                  "type": "string"
                },
                "path": {
                  "minLength": 1,
                  "type": "string"
                },
                "sha256": {
                  "pattern": "^sha256:[0-9a-f]{64}$",
                  "type": "string"
                },
                "size_bytes": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "git_object_id",
                "path",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "missing_probe_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "plausibility_state": {
            "const": "no_direct_candidate_level_admission_surface_observed"
          },
          "probes": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "matches": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "occurrences": {
                        "minimum": 1,
                        "type": "integer"
                      },
                      "path": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "term": {
                        "minLength": 1,
                        "type": "string"
                      }
                    },
                    "required": [
                      "occurrences",
                      "path",
                      "term"
                    ],
                    "type": "object"
                  },
                  "type": "array"
                },
                "probe_id": {
                  "minLength": 1,
                  "type": "string"
                },
                "satisfied": {
                  "type": "boolean"
                },
                "terms": {
                  "items": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "minItems": 1,
                  "type": "array",
                  "uniqueItems": true
                }
              },
              "required": [
                "matches",
                "probe_id",
                "satisfied",
                "terms"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "blob_count",
          "blob_set_digest",
          "candidate_group",
          "candidate_id",
          "candidate_manifest_digest",
          "capability_id",
          "coverage",
          "inspected_blobs",
          "missing_probe_ids",
          "plausibility_state",
          "probes"
        ],
        "type": "object"
      },
      "maxItems": 12,
      "minItems": 12,
      "type": "array"
    },
    "claim_boundary": {
      "const": "plausibility_screen_only_no_qualification_or_disposition"
    },
    "coverage": {
      "additionalProperties": false,
      "properties": {
        "expected": {
          "minimum": 12,
          "type": "integer"
        },
        "scanned": {
          "minimum": 12,
          "type": "integer"
        },
        "unreadable": {
          "const": 0
        },
        "unverified": {
          "const": 0
        }
      },
      "required": [
        "expected",
        "scanned",
        "unreadable",
        "unverified"
      ],
      "type": "object"
    },
    "derivation_artifacts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "digest": {
            "pattern": "^sha256:[0-9a-f]{64}$",
            "type": "string"
          },
          "relative_path": {
            "minLength": 1,
            "type": "string"
          },
          "size_bytes": {
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "digest",
          "relative_path",
          "size_bytes"
        ],
        "type": "object"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array"
    },
    "evidence_version": {
      "const": "1.0.0"
    },
    "oracle_activation": {
      "const": false
    },
    "qualification_interfaces": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "digest",
        "relative_path",
        "size_bytes"
      ],
      "type": "object"
    },
    "qualification_test_vectors": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "digest",
        "relative_path",
        "size_bytes"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "pmorg.candidate-interface-fit-evidence/v1"
    },
    "selection_policy": {
      "additionalProperties": false,
      "properties": {
        "deployment-admission": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 6,
          "minItems": 6,
          "type": "array",
          "uniqueItems": true
        },
        "distribution-admission": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 6,
          "minItems": 6,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "deployment-admission",
        "distribution-admission"
      ],
      "type": "object"
    },
    "source_commit": {
      "const": "1da679cefc96165c6b9b64c3bc769584b88f88c2"
    },
    "source_repository": {
      "const": "https://github.com/onyx-dot-app/onyx.git"
    },
    "source_tree_id": {
      "const": "7696e9ff17a5ddc9acc0e7e21a1d213925056a58"
    }
  },
  "required": [
    "schema_version",
    "evidence_version",
    "source_repository",
    "source_commit",
    "source_tree_id",
    "candidate_inputs",
    "qualification_interfaces",
    "qualification_test_vectors",
    "derivation_artifacts",
    "selection_policy",
    "candidates",
    "candidate_count",
    "coverage",
    "claim_boundary",
    "oracle_activation"
  ],
  "title": "PMORG candidate interface-fit evidence",
  "type": "object"
}
